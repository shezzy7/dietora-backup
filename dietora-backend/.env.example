# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dietora?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Admin Seed ───────────────────────────────────────────
ADMIN_EMAIL=admin@dietora.pk
ADMIN_PASSWORD=Admin@12345

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Google OAuth ─────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5173
# 5. Copy the Client ID below (same value goes in frontend .env too)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# ─── AI & Maps APIs ───────────────────────────────────────
# Groq API for free AI models (LLaMA, Mixtral, etc.)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=

# Google Places for store discovery
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ─── Frontend Origin ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
